{
  "name": "@vortex/db",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": "./dist/index.js"
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5",
    "vitest": "^3.2.7"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/sql && cp src/sql/*.sql dist/sql/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "migrate:export": "tsx src/migration/export.ts",
    "migrate:import": "tsx src/migration/import.ts",
    "migrate:verify": "tsx src/migration/verify.ts",
    "migrate:auth-secrets": "tsx src/migration/auth-secrets-export.ts",
    "migrate:run": "tsx src/migration/run.ts",
    "migrate:dry-run": "tsx src/migration/run.ts --dry-run --auth-secrets"
  }
}
