# ─── Database (SQLite) ────────────────────────────────────────────────────────
# See packages/db/src/db-path.ts. Same file/convention as docker-compose.yml.
# DATABASE_URL=file:/data/vortex.db

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Web Push notifications ───────────────────────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key          # server-side only
VAPID_SUBJECT=mailto:admin@example.com             # mailto: or https: URL

# ─── Self-hosted push via ntfy (issue #38) ────────────────────────────────────
# Optional alternative/companion to Web Push above that never routes through
# Google FCM / Apple APNs. Point this at your own ntfy server (the bundled
# docker-compose.yml ships one at http://ntfy:80 on the internal network).
# Hidden in Settings → Notifications until NTFY_SERVER_URL is set.
NTFY_SERVER_URL=http://localhost:8080             # server-side only — used to publish
NEXT_PUBLIC_NTFY_URL=http://localhost:8080         # public URL clients subscribe to
# Optional — only needed if your ntfy server has auth enabled for publishing
# NTFY_ACCESS_TOKEN=your-ntfy-access-token          # server-side only

# ─── Error monitoring (Sentry) ────────────────────────────────────────────────
# Create a project at sentry.io and paste the DSN here.
# NEXT_PUBLIC_SENTRY_DSN is safe to expose to the browser.
NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
# Optional: set org/project for source map uploads during CI builds
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-auth-token   # server-side only

# ─── Redis (rate limiting + application cache) ───────────────────────────────
# Required for multi-instance deployments (in-memory fallback used otherwise).
#
# Option A — Standard Redis (self-hosted / Docker / any Redis server):
# REDIS_URL=redis://localhost:6379
#
# Option B — Upstash Redis (serverless / Vercel):
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token       # server-side only
#
# If both are set, REDIS_URL takes priority.

# ─── Livekit (voice channels) ─────────────────────────────────────────────────
# Optional — if not set, voice channels return 503 Unavailable.
# Get credentials from livekit.io or your self-hosted LiveKit server.
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret        # server-side only
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
# Optional — server-to-server LiveKit host (RoomServiceClient) used only for
# the defense-in-depth createRoom() call in the DM call token route.
LIVEKIT_API_URL=http://localhost:7880

# ─── AI summarization (Gemini) ────────────────────────────────────────────────
# Gemini API keys are now configured per-server by each server owner
# in Server Settings → AI. No instance-level env var needed.

# ─── Steam Web API (social connections enrichment) ──────────────────────────
# Optional — if set, Steam connections will show the user's display name,
# avatar, and owned game count on their profile.
# Get a key from https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=your-steam-web-api-key            # server-side only

# ─── Google / YouTube OAuth (social connections) ────────────────────────────
# Required for YouTube channel connection via Google sign-in.
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Enable the "YouTube Data API v3" in your Google Cloud project.
# Set authorized redirect URI to: https://your-app.vercel.app/api/users/connections/youtube/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret      # server-side only

# ─── GIF search (Klipy primary, Giphy fallback) ──────────────────────────────
# Optional — if neither is set, the GIF picker is hidden in the UI.
# Klipy is preferred when both are configured (primary provider).
# Server-side keys (recommended — keeps secrets off the client):
# Klipy: get a key from partner.klipy.com
KLIPY_API_KEY=your-klipy-api-key                  # server-side only
# Giphy: get a key from developers.giphy.com (fallback only)
GIPHY_API_KEY=your-giphy-api-key                  # server-side only
# Public fallbacks — only needed if you must expose keys to the browser
# (e.g. client-side GIF picker without an API proxy). The server-side
# keys above are preferred; these are optional.
# NEXT_PUBLIC_KLIPY_API_KEY=your-klipy-api-key
# NEXT_PUBLIC_GIPHY_API_KEY=your-giphy-api-key

# ─── Cron job protection ──────────────────────────────────────────────────────
# Required to authenticate scheduled cleanup jobs. The self-hosted cron runner
# (apps/cron) sends this as a Bearer token to /api/cron/* endpoints.
# Set to a random secret: openssl rand -hex 32
CRON_SECRET=your-cron-secret                      # server-side only

# ─── OEmbed security ──────────────────────────────────────────────────────────
# Optional comma-separated list of domains to block from link previews.
# EMBED_BLOCKED_DOMAINS=example.com,badsite.net

# ─── Realtime gateway (apps/signal — Socket.IO) ───────────────────────────────
# The web app talks to the signal server for realtime fan-out (messages,
# presence, typing) and session/channel revocation.
#
# SIGNAL_REVOKE_SECRET is a shared secret the web app sends to the signal
# server as a Bearer token (and the signal server sends back for its
# channel-membership check). It MUST match apps/signal's SIGNAL_REVOKE_SECRET.
# If it is unset, gateway-publish.ts SILENTLY SKIPS all realtime fan-out —
# the app still works but realtime is degraded with no error. Set it.
# Generate with: openssl rand -hex 32
SIGNAL_REVOKE_SECRET=your-signal-revoke-secret    # server-side only
# Server-side base URL the web app uses to reach the signal server (an HTTP(S)
# URL — this is a server-to-server fetch, NOT a browser WebSocket). Defaults to
# NEXT_PUBLIC_SIGNAL_URL, then http://localhost:3001. In docker-compose this is
# auto-set to http://signal:3001; override only if signal runs elsewhere.
# SIGNAL_SERVER_URL=http://localhost:3001
# Public WebSocket URL browsers connect to for the realtime gateway. Also used
# as the server-side fallback when SIGNAL_SERVER_URL is unset.
NEXT_PUBLIC_SIGNAL_URL=ws://localhost:3001

# ─── Step-up authentication ───────────────────────────────────────────────────
# Dedicated HMAC secret for step-up auth tokens. Required in production.
# Must NOT reuse NEXTAUTH_SECRET — generate a separate value: openssl rand -hex 32
STEP_UP_SECRET=your-step-up-secret                # server-side only
# Optional — set to the PREVIOUS STEP_UP_SECRET during a zero-downtime key
# rotation so tokens signed with the old key still verify. Remove it once the
# step-up token TTL (10 min) has elapsed after deploying the new secret.
# STEP_UP_SECRET_PREV=your-previous-step-up-secret # server-side only

# ─── WebAuthn / Passkeys (optional overrides) ─────────────────────────────────
# Defaults to the hostname of NEXT_PUBLIC_APP_URL. Override only if needed.
# NEXT_PUBLIC_WEBAUTHN_RP_ID=your-domain.com
# NEXT_PUBLIC_APP_ORIGIN=https://your-domain.com

# ─── Better Auth (issue #8 — replaces Supabase Auth) ──────────────────────────
# Session/cookie/JWT signing secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret          # server-side only, required in production
# SQLite file Better Auth's own tables (accounts/sessions/passkeys/etc.) live
# in — see packages/db/src/db-path.ts. Same file/convention as docker-compose.yml.
# DATABASE_URL=file:/data/vortex.db
# SMTP — required for verification/reset/magic-link emails to actually send;
# without it, auth still works but emails are logged and skipped (dev-friendly).
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password                   # server-side only
# EMAIL_FROM="Vortex <no-reply@your-domain.com>"

# ─── OAuth (GitHub / Twitch / Reddit connections) ─────────────────────────────
# Each provider is only registered if BOTH its id and secret are set — omit a
# pair to leave that provider disabled. Previously configured on Supabase's
# own dashboard; now Better Auth's own credentials.
# Redirect URI to register with each provider: <APP_ORIGIN>/api/auth/callback/<provider>
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret      # server-side only
# TWITCH_CLIENT_ID=your-twitch-client-id
# TWITCH_CLIENT_SECRET=your-twitch-client-secret      # server-side only
# REDDIT_CLIENT_ID=your-reddit-client-id
# REDDIT_CLIENT_SECRET=your-reddit-client-secret      # server-side only
