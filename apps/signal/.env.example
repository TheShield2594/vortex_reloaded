# Port for the signaling server
PORT=3001

# CORS — comma-separated list of allowed origins (REQUIRED in production)
# Must be set explicitly in production — the server will exit if this is
# missing or set to "*" when NODE_ENV=production.
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Redis — optional. When set:
#   The Socket.IO Redis adapter is attached so that socket-room broadcasts
#   (e.g. gateway:event, gateway:presence) are fanned out to every replica —
#   this allows Railway to run multiple signal-server instances. It also
#   backs the event bus and presence manager.
# Leave unset to use the default in-process adapter (single-instance only).
# REDIS_URL=redis://localhost:6379

# Shared secret for the /revoke-token endpoint. The web app must send this as
# a Bearer token when notifying the signal server of session revocations.
# Generate with: openssl rand -hex 32
# SIGNAL_REVOKE_SECRET=your-shared-secret

# Better Auth JWKS — handshake auth verification.
# Point at apps/web's own origin, reachable from wherever apps/signal runs
# (e.g. the Docker service name in docker-compose.yml, not necessarily the
# same public URL a browser would use).
AUTH_JWKS_URL=http://web:3000/api/auth/jwks
AUTH_JWT_ISSUER=http://localhost:3000
AUTH_JWT_AUDIENCE=vortex-signal

# Log level: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info
