# LiveKit self-hosted config template.
#
# Do not edit this file directly and do not commit the generated version —
# `scripts/setup.sh` reads this template and writes a real ./livekit.yaml
# (with actual secrets filled in) at the repo root, which docker-compose.yml
# mounts into the livekit container. ./livekit.yaml is gitignored.
#
# Full reference: https://github.com/livekit/livekit/blob/master/config-sample.yaml

port: 7880

rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 50019
  # Auto-detects this host's public IP via STUN for ICE candidates. If this
  # box is behind NAT with manual port-forwarding (e.g. a home server),
  # replace this with `node_ip: "YOUR.PUBLIC.IP.ADDRESS"` instead.
  use_external_ip: true

# We run a separate coturn container rather than LiveKit's embedded TURN
# server (turn.enabled), so clients that can't reach LiveKit directly over
# UDP/TCP fall back to relaying through coturn instead.
turn:
  enabled: false

turn_servers:
  - host: __TURN_EXTERNAL_IP__
    port: 3478
    protocol: udp
    secret: __TURN_SECRET__

room:
  # Rooms are created implicitly on first participant join. VortexChat's
  # token-mint API route enforces DM/group-channel membership before ever
  # issuing a join token, so this default is fine — LiveKit itself has no
  # separate membership concept, the signed token IS the authorization.
  auto_create: true

keys:
  __LIVEKIT_API_KEY__: __LIVEKIT_API_SECRET__

# No `redis:` block — this is a single-node deployment. Add one (matching
# the `redis` service already in docker-compose.yml) only if you later run
# more than one livekit-server replica and need shared room state.
